-- === Helper Function: Create Button ===
local function createButton(text, layoutOrder, color)
	local Btn = Instance.new("TextButton")
	Btn.Name = text .. "Button"
	Btn.Size = UDim2.new(1, 0, 0, 65)
	Btn.BackgroundColor3 = color or Color3.fromRGB(50, 110, 200)
	Btn.Text = ""
	Btn.BorderSizePixel = 0
	Btn.LayoutOrder = layoutOrder
	Btn.AutoButtonColor = false
	Btn.Parent = ContentFrame

	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 8)
	BtnCorner.Parent = Btn

	local BtnLabel = Instance.new("TextLabel")
	BtnLabel.Size = UDim2.new(1, 0, 1, 0)
	BtnLabel.BackgroundTransparency = 1
	BtnLabel.Text = text
	BtnLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	BtnLabel.TextSize = 15
	BtnLabel.Font = Enum.Font.GothamSemibold
	BtnLabel.Parent = Btn

	-- Hover effect
	Btn.MouseEnter:Connect(function()
		Btn.BackgroundColor3 = Btn.BackgroundColor3:Lerp(Color3.fromRGB(255, 255, 255), 0.15)
	end)
	Btn.MouseLeave:Connect(function()
		Btn.BackgroundColor3 = color or Color3.fromRGB(50, 110, 200)
	end)
	Btn.MouseButton1Down:Connect(function()
		Btn.BackgroundColor3 = Btn.BackgroundColor3:Lerp(Color3.fromRGB(0, 0, 0), 0.2)
	end)
	Btn.MouseButton1Up:Connect(function()
		Btn.BackgroundColor3 = color or Color3.fromRGB(50, 110, 200)
	end)

	return Btn
end

-- === Buttons ===
local Button1 = createButton("✅  Accepter", 1, Color3.fromRGB(50, 110, 200))
local Button2 = createButton("💎  Button Placeholder 2", 2, Color3.fromRGB(80, 170, 100))

-- === Accepter Logic ===
local AcceptTrade = game:GetService("ReplicatedStorage"):WaitForChild("Trade"):WaitForChild("AcceptTrade")
local accepting = false
local acceptLoop = nil

Button1.MouseButton1Click:Connect(function()
	accepting = not accepting

	if accepting then
		-- Update button to show active state
		Button1.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
		local label = Button1:FindFirstChildOfClass("TextLabel")
		if label then label.Text = "🛑  Stop Accepting" end

		-- Start firing every 0.1 seconds
		acceptLoop = task.spawn(function()
			while accepting do
				AcceptTrade:FireServer()
				task.wait(0.1)
			end
		end)
	else
		-- Stop the loop
		accepting = false
		Button1.BackgroundColor3 = Color3.fromRGB(50, 110, 200)
		local label = Button1:FindFirstChildOfClass("TextLabel")
		if label then label.Text = "✅  Accepter" end
	end
end)

